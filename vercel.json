{
  "buildCommand": "prisma generate && next build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["fra1"],
  "env": {
    "DATABASE_URL": "@viktoria-database-url",
    "DIRECT_URL": "@viktoria-direct-url",
    "NEXTAUTH_SECRET": "@viktoria-nextauth-secret",
    "NEXTAUTH_URL": "@viktoria-nextauth-url",
    "STRIPE_SECRET_KEY": "@viktoria-stripe-secret",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY": "@viktoria-stripe-public",
    "EMAIL_SERVER_HOST": "@viktoria-email-host",
    "EMAIL_SERVER_PORT": "@viktoria-email-port",
    "EMAIL_SERVER_USER": "@viktoria-email-user",
    "EMAIL_SERVER_PASSWORD": "@viktoria-email-password",
    "EMAIL_FROM": "@viktoria-email-from"
  }
}
